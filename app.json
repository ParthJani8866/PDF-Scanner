{
  "expo": {
    "name": "DocVault",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.docvault.asvf39",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan documents with the camera",
        "NSPhotoLibraryUsageDescription": "Import photos to convert to PDF",
        "NSPhotoLibraryAddUsageDescription": "Save scanned PDFs to your library"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.docvault.asvf39",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow DocVault to access your camera to scan documents."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow DocVault to access your photos to convert them to PDF."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#050314"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
